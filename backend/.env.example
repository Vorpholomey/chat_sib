# App — local dev: DEBUG=true + placeholder SECRET_KEY is fine. Production: DEBUG=false and SECRET_KEY ≥ 32 random chars (not the placeholder).
DEBUG=false

# Comma-separated browser origins, e.g. https://chat.example.com (required for cross-origin API when DEBUG=false)
CORS_ORIGINS=*

# PostgreSQL – use a role that exists on your machine.
# If you get "role postgres does not exist", use your OS username (often no password on macOS):
#   DATABASE_URL=postgresql+asyncpg://YOUR_OS_USERNAME@localhost:5432/chat_db
#   DATABASE_URL_SYNC=postgresql://YOUR_OS_USERNAME@localhost:5432/chat_db
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chat_db
#   DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/chat_db


# Redis (optional, for future caching)
REDIS_URL=redis://localhost:6379/0

# JWT – use a long random string in production
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP (password recovery). Leave SMTP_HOST empty in dev to skip sending; the API logs the temporary password at WARNING.
# Mail.ru / @mail.ru / @list.ru: outgoing server is always smtp.mail.ru (not list.ru). Port 465 = SSL from connect; 587 = STARTTLS.
# IMAP is only for reading mail — not used by this app.
# Example (placeholders):
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#   SMTP_USER=your_address@list.ru
#   SMTP_PASSWORD=your_app_password
#   SMTP_FROM=your_address@list.ru
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=60

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
