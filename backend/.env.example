# App
DEBUG=false

# PostgreSQL – use a role that exists on your machine.
# If you get "role postgres does not exist", use your OS username (often no password on macOS):
#   DATABASE_URL=postgresql+asyncpg://YOUR_OS_USERNAME@localhost:5432/chat_db
#   DATABASE_URL_SYNC=postgresql://YOUR_OS_USERNAME@localhost:5432/chat_db
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chat_db
#   DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/chat_db


# Redis (optional, for future caching)
REDIS_URL=redis://localhost:6379/0

# JWT – use a long random string in production
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
